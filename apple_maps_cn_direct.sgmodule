#!name=Apple Maps CN Direct (macOS)
#!desc=Force Apple Maps traffic to DIRECT for better performance in mainland China
#!author=ChatGPT
#!system=macOS

[Rule]

# Apple Maps Core Services
DOMAIN-SUFFIX,ls.apple.com,DIRECT
DOMAIN-SUFFIX,gspe1-ssl.ls.apple.com,DIRECT
DOMAIN-SUFFIX,gspe35-ssl.ls.apple.com,DIRECT
DOMAIN-SUFFIX,gspe19-ssl.ls.apple.com,DIRECT
DOMAIN-SUFFIX,gspe12-ssl.ls.apple.com,DIRECT
DOMAIN-SUFFIX,gspe79-ssl.ls.apple.com,DIRECT

# Apple Maps Tiles and Resources
DOMAIN-SUFFIX,cdn.apple-mapkit.com,DIRECT
DOMAIN-SUFFIX,apple-mapkit.com,DIRECT
DOMAIN-SUFFIX,apple.com,DIRECT

# Location Services
DOMAIN-SUFFIX,locationd.apple.com,DIRECT

# Apple Geo Services
DOMAIN-SUFFIX,geo.apple.com,DIRECT
DOMAIN-SUFFIX,geo2.apple.com,DIRECT

# Apple CDN China (operated by GCBD / ChinaNet)
DOMAIN-SUFFIX,apple.cn,DIRECT
DOMAIN-SUFFIX,icloud.com,DIRECT
DOMAIN-SUFFIX,icloud-content.com,DIRECT

# Apple Maps China partner (AutoNavi / Gaode)
DOMAIN-SUFFIX,amap.com,DIRECT
DOMAIN-SUFFIX,autonavi.com,DIRECT

[Host]

# Force China Geo endpoint resolution
gspe1-ssl.ls.apple.com = gspe1-cn-ssl.ls.apple.com
